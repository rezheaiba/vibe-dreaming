.container {
  min-height: 100vh;
  background: #fdfdfd;
  padding: 30rpx 30rpx 250rpx 30rpx;
  box-sizing: border-box;
}

.loading-state { text-align: center; padding-top: 100rpx; color: #ccc; font-size: 28rpx; }

.detail-page {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 内容卡片 */
.content-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.02);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background: #f0f4ff;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}
.status-tag.pub { background: #f0f4ff; color: #6a11cb; }
.status-tag.priv { background: #f5f5f5; color: #999; }

.main-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #444;
  display: block;
}

.edit-field {
  width: 100%;
  min-height: 300rpx;
  font-size: 32rpx;
  line-height: 1.6;
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 16rpx;
}

/* AI 板块 */
.ai-container {
  margin-top: 50rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ai-item {
  padding: 30rpx;
  border-radius: 24rpx;
}

/* 统一各板块视觉风格 */
.ai-item.refine { background: #f8f9ff; border-left: 8rpx solid #6a11cb; }
.ai-item.expand { background: #fcf8ff; border-left: 8rpx solid #9b59b6; }
.ai-item.analyze { background: #fffaf8; border-left: 8rpx solid #ff9f43; }

.ai-label {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.ai-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
}

/* 评论区交互 */
.comments-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.02);
  margin-top: 30rpx;
}

.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 30rpx; }

.comment-floor {
  margin-bottom: 40rpx;
}

.comment-main {
  margin-bottom: 20rpx;
}

.reply-area {
  margin-left: 60rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #f5f5f5;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 15rpx;
}

.reply-item {
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #eee;
}
.reply-item:last-child { border-bottom: none; margin-bottom: 0; }

.c-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.c-user { font-size: 24rpx; font-weight: bold; color: #6a11cb; }
.c-reply-to { font-size: 22rpx; color: #999; margin-left: 10rpx; }

.c-right { display: flex; align-items: center; gap: 20rpx; }
.c-like { font-size: 22rpx; color: #999; display: flex; align-items: center; gap: 4rpx; }
.c-like.active { color: #ff4757; }
.l-count { font-size: 20rpx; }

.c-delete { font-size: 20rpx; color: #ff4757; opacity: 0.8; }

.c-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.5;
  display: block;
}

.c-content.deleted {
  color: #ccc;
  font-style: italic;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 40rpx; left: 30rpx; right: 30rpx; height: 110rpx;
  background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
  border-radius: 55rpx; display: flex; align-items: center; padding: 0 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05); z-index: 100;
}
.view-actions { display: flex; width: 100%; justify-content: space-between; }
.social-group { display: flex; gap: 30rpx; }
.icon-box { display: flex; align-items: center; gap: 6rpx; }
.icon { font-size: 36rpx; }
.count { font-size: 20rpx; color: #999; }
.owner-group { display: flex; gap: 15rpx; align-items: center; }
.circle-btn { width: 64rpx; height: 64rpx; background: #f5f5f5; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.circle-btn.danger { color: #ff4757; background: #fff0f0; }

.pill-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}
.pill-btn.cancel { background: #f5f5f5; color: #666; margin-right: 15rpx; }
.pill-btn.save { background: #6a11cb; color: white; }

.comment-input-area {
  position: fixed; bottom: 170rpx; left: 30rpx; right: 30rpx; height: 80rpx;
  background: white; border-radius: 40rpx; display: flex; align-items: center; padding: 0 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.04); z-index: 99;
}
.ci-field { flex: 1; font-size: 26rpx; }
.ci-send { color: #6a11cb; font-weight: bold; font-size: 26rpx; margin-left: 20rpx; }
