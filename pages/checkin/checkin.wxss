.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.stats-card {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.stat-item {
  text-align: center;
  color: white;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

.stat-more {
  display: block;
  font-size: 28rpx;
}

.checkin-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.checkin-btn {
  width: 100%;
  background: #6a11cb;
  color: white;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
}

.checkin-btn.checked {
  background: #52c41a;
}

.calendar-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.current-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f0f0f0;
  border-radius: 50%;
  padding: 0;
  font-size: 28rpx;
  line-height: 60rpx;
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 10rpx;
}

.weekday {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
  font-weight: bold;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  border-radius: 50%;
}

.calendar-day.other-month {
  color: #eee;
}

.calendar-day.checked {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: white;
}

.tips {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
