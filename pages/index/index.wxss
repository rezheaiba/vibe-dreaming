.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
  padding: 60rpx 0;
}

.title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card {
  background: rgba(255, 255, 255, 0.95);
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

label {
  display: block;
  margin-bottom: 15rpx;
  font-weight: bold;
  color: #333;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 30rpx;
  line-height: 1.6;
}

.btn {
  width: 100% !important;
  border-radius: 50rpx;
  font-weight: normal;
  font-size: 30rpx;
  padding: 20rpx 0;
}

.btn-primary {
  background: #6a11cb;
  color: white;
}

/* 登录后样式 */
.add-dream-card {
  background: white;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.search-box {
  background: white;
  border-radius: 50rpx;
  padding: 10rpx 25rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.search-input {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 140rpx !important;
  height: 60rpx;
  padding: 0;
  line-height: 60rpx;
  font-size: 24rpx;
  background: #6a11cb;
  color: white;
  border-radius: 30rpx;
  margin-left: 10rpx;
}

.dream-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding-bottom: 40rpx;
}

.dream-item-card {
  background: white;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.dream-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.dream-date {
  font-size: 24rpx;
  color: #999;
}

.dream-badge {
  background: #f0f4ff;
  color: #6a11cb;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dream-preview {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.ai-tags {
  display: flex;
  gap: 10rpx;
}

.ai-tag {
  background: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.empty-msg {
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  padding: 80rpx 0;
  font-size: 28rpx;
}
