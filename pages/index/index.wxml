<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!currentUser}}">
    <view class="header">
      <text class="title">巡游梦境</text>
      <text class="subtitle">探索潜意识的奇妙世界</text>
    </view>

    <!-- 自动登录中 -->
    <view wx:if="{{isLoginLoading}}" class="loading-state">
      <view class="spinner"></view>
      <text>正在连接梦境网络...</text>
    </view>

    <!-- 登录表单（自动登录失败或初始状态） -->
    <view wx:else class="login-form">
      <view class="input-group">
        <input 
          class="input" 
          placeholder="起一个织梦者的名字..." 
          value="{{username}}" 
          bindinput="handleInput" 
          data-field="username"
        />
      </view>
      <button class="btn btn-primary" bindtap="login">开启梦境旅程</button>
      <view class="login-hint">提示：若已绑定微信，下次将自动登录</view>
    </view>
  </view>

  <!-- App Content -->
  <view wx:else>
    <view class="add-dream-card">
      <view class="form-group">
        <textarea 
          class="textarea" 
          placeholder="记录昨晚的梦境...✨" 
          value="{{dreamInput}}"
          bindinput="handleInput"
          data-field="dreamInput"
          maxlength="-1"
          auto-height
        />
      </view>
      <view class="ai-toggle-row">
        <view class="ai-toggle-label">
          <text class="ai-toggle-icon">🔮</text>
          <text>自动使用 AI 解析</text>
        </view>
        <switch 
          checked="{{autoAi}}" 
          bindchange="toggleAutoAi" 
          color="#6a11cb"
          style="transform: scale(0.8);"
        />
      </view>
      <button class="btn btn-primary" bindtap="submitDream">✨ 记录梦境</button>
    </view>

    <!-- 搜索框 -->
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索梦境关键词..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <button class="search-btn" bindtap="onSearch">🔍 搜索</button>
    </view>

    <!-- 梦境列表（按时间倒序） -->
    <view class="dream-list">
      <view wx:if="{{filteredDreams.length === 0}}" class="empty-msg">
        {{searchKeyword ? '未找到相关梦境' : '尚无记录，快去记录第一个梦吧！'}}
      </view>

      <view 
        wx:for="{{filteredDreams}}" 
        wx:key="id" 
        class="dream-item-card"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="dream-header">
          <view class="dream-date">{{item.formattedDate}}</view>
          <view class="dream-badge" wx:if="{{item.is_public === 1}}">🌍 公开</view>
        </view>
        <view class="dream-preview">{{item.shortContent}}</view>
        <view class="ai-tags">
          <text wx:if="{{item.refined_content}}" class="ai-tag">✨ 精炼</text>
          <text wx:if="{{item.expanded_content}}" class="ai-tag">🌌 扩充</text>
          <text wx:if="{{item.analysis_content}}" class="ai-tag">🔮 解梦</text>
        </view>
      </view>
    </view>
  </view>
</view>
