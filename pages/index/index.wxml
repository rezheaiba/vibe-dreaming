<view class="container">
  <view class="header">
    <text class="title">巡游梦境</text>
  </view>

  <!-- Login Section -->
  <view wx:if="{{!currentUser}}" class="card section">
    <view class="form-group">
      <label>请输入您的昵称：</label>
      <input 
        class="input" 
        placeholder="例如：织梦人" 
        value="{{username}}"
        bindinput="handleInput"
        data-field="username"
      />
    </view>
    <button class="btn btn-primary" bindtap="login">开启梦境之旅</button>
  </view>

  <!-- App Content -->
  <view wx:else class="full-width">
    <view class="welcome-section">
      <text>欢迎回来，</text>
      <text class="username">{{currentUser.username}}</text>
      <text class="logout-link" bindtap="logout"> [退出]</text>
    </view>

    <view class="card section">
      <view class="form-group">
        <label>记下您的梦境：</label>
        <textarea 
          class="textarea" 
          placeholder="昨晚我梦见..." 
          value="{{dreamInput}}"
          bindinput="handleInput"
          data-field="dreamInput"
          maxlength="-1"
        />
      </view>
      <button class="btn btn-primary" bindtap="submitDream">提交到梦库</button>
    </view>

    <view class="history-section">
      <view class="history-title">历史梦境记录</view>
      
      <view wx:if="{{dreamHistory.length === 0}}" class="empty-msg">
        尚无记录，快去记录第一个梦吧！
      </view>

      <view wx:for="{{dreamHistory}}" wx:key="id" class="dream-card">
        <view class="dream-date">{{item.formattedDate}}</view>
        <view class="dream-content">{{item.raw_content}}</view>
        
        <view class="ai-section">
          <view class="ai-badge">✨ AI 精炼</view>
          <view class="ai-content">{{item.refined_content || '处理中...'}}</view>
          
          <view class="ai-badge">🌌 AI 扩充</view>
          <view class="ai-content">{{item.expanded_content || '处理中...'}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
