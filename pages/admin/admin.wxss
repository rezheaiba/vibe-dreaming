.container {
  height: 100vh;
  background: #f8f9fc;
  display: flex;
  flex-direction: column;
  width: 100%;
}

/* 用户名片 */
.user-card {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  padding: 50rpx 40rpx;
  color: white;
  width: 100%;
  box-sizing: border-box;
}

.user-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.username {
  font-size: 38rpx;
  font-weight: bold;
}

.level-tag {
  font-size: 20rpx;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.signature-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.signature {
  font-size: 24rpx;
  opacity: 0.85;
}

.logout-icon {
  font-size: 22rpx;
  background: rgba(255,255,255,0.15);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

/* 选项卡容器：修正重叠与对齐宽度 */
.tab-container {
  background: white;
  width: 100%;
  padding: 30rpx 40rpx; /* 侧边边距 40rpx 与 user-card 保持一致 */
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
  z-index: 10;
  /* 移除了导致重叠的 margin-top 负值 */
}

.tab-list {
  display: flex;
  background: #f5f6f9;
  border-radius: 45rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
  white-space: nowrap; /* 确保不换行 */
}

.tab-item.active {
  background: white;
  color: #6a11cb;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 列表容器 */
.list-scroll {
  flex: 1;
  overflow: hidden;
}

.list-container {
  padding: 20rpx 30rpx;
}

.dream-row {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02);
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.row-date {
  font-size: 22rpx;
  color: #bbb;
}

.row-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.row-ops {
  display: flex;
  gap: 15rpx;
}

.op-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f8f9fc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.op-btn.danger {
  background: #fff0f0;
}

.empty-msg {
  text-align: center;
  padding: 150rpx 0;
  color: #ccc;
  font-size: 26rpx;
}
